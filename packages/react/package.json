  },
  "devDependencies": {
    "@tanstack/react-query": "^5.100.10",
    "@types/react": "^18.3.28",
    "typescript": "^5.9.3"
  },
  "keywords": ["canton", "daml", "react", "hooks", "canton-network"],
  "license": "Apache-2.0"
